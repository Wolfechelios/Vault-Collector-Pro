{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vault Catalogue",
  "version": "0.1.0",
  "identifier": "com.wolfe.vaultcatalogue",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vault Catalogue",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "app"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}